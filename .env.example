# Razorpay (required for live payments)
# Get your keys from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# Google Analytics 4 (optional but recommended for tracking conversions)
# Get from: analytics.google.com → Admin → Data Streams → Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Public URL (used for og/meta, optional)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Set to "true" to skip payment and allow free downloads in local dev
NEXT_PUBLIC_ALLOW_DEV_DOWNLOAD=true
